# Copy this file to .env.local (kept out of git) and fill in values from
# Firebase console → Project settings → "Your apps" → Web app config.
# Restart `npm run dev` after editing.

# Backend origin.
# Local dev: leave empty — Vite dev server proxies /api to
#            http://localhost:4000 (see vite.config.js).
# Vercel / prod: set to the API origin only (no trailing /api), e.g.
#                https://tms-api.vercel.app
# If you set .../vercel.app/api, requests will hit /api/api/... and fail with 404.
# The older VITE_API_URL is still read as a fallback.
VITE_API_BASE_URL=

# Optional: same as backend origin for Vercel serverless proxy (frontend/api/[...path].js).
# If unset, the proxy uses VITE_API_BASE_URL. Set on Vercel if you only expose the frontend URL.
# BACKEND_API_URL=

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
