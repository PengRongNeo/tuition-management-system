# -----------------------------------------------------------------------------
# Firebase Admin credentials
# -----------------------------------------------------------------------------
# Option A (local dev): point to a service account JSON file on disk.
# Generate one from Firebase Console > Project Settings > Service Accounts.
# Keep the file outside of git (it is already ignored). Path is relative to
# the backend/ folder or absolute.
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Option B (Vercel / production): provide the values as env vars. Required on
# Vercel because there is no persistent filesystem. Copy each field from the
# service account JSON. The private key must keep its literal \n sequences if
# you paste it as a single line.
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# -----------------------------------------------------------------------------
# Firebase Auth REST API (admin email/password login through the backend)
# -----------------------------------------------------------------------------
# From Firebase Console > Project Settings > General > Web API Key.
FIREBASE_WEB_API_KEY=your-web-api-key

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
# Port is only used when running locally (node / npm run dev). Vercel ignores
# this and routes all traffic through its serverless runtime.
PORT=4000

# Allowed frontend origins for CORS. Comma-separated — add the Vercel URL(s)
# of the deployed frontend here once it is live.
# Examples:
#   FRONTEND_ORIGIN=http://localhost:3000
#   FRONTEND_ORIGIN=http://localhost:3000,https://tms.vercel.app
#   FRONTEND_ORIGIN=*   # (open to any origin; not recommended in production)
FRONTEND_ORIGIN=http://localhost:3000

# -----------------------------------------------------------------------------
# Google Form → pending students (optional)
# -----------------------------------------------------------------------------
# Long random string. When set, POST /api/public/student-from-form requires
# header: X-Form-Secret: <this value>
# FORM_SUBMIT_SECRET=your-long-random-secret-string

# -----------------------------------------------------------------------------
# Telegram lesson reminders (optional)
# -----------------------------------------------------------------------------
# Create a bot via @BotFather, then set the token here (never expose to frontend).
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
#
# Public URL of the lesson submission SPA (no trailing slash). Used in reminder links.
# APP_BASE_URL=https://your-frontend.vercel.app
#
# Webhook URL for Telegram → your backend POST /api/public/telegram/webhook
# (set via https://api.telegram.org/bot<token>/setWebhook). Optional secret:
# TELEGRAM_WEBHOOK_SECRET=random-string-matching-setWebhook-secret_token
#
# Vercel Cron (or curl) should call GET /api/cron/telegram-lesson-reminders with this header:
#   Authorization: Bearer <CRON_SECRET>
# or: x-cron-secret: <CRON_SECRET>
# CRON_SECRET=long-random-string
#
# Reminder times use this IANA zone (default Singapore).
# APP_TIMEZONE=Asia/Singapore
