# Firebase Admin SDK - path to service account JSON (recommended: keep in backend folder, not in node_modules)
# Create backend/serviceAccountKey.json from Firebase Console > Project Settings > Service Accounts
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Option 2: Or set these if you prefer (private key as single line, replace newlines with \n)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Firebase Web API Key (for Auth REST API - from Firebase Console > Project Settings > General)
FIREBASE_WEB_API_KEY=your-web-api-key

# Server port
PORT=4000

# Frontend origin for CORS (e.g. http://localhost:3000)
FRONTEND_ORIGIN=http://localhost:3000

# Secret for Google Form → student creation (optional). Use a long random string.
# If set, POST /api/public/student-from-form requires header: X-Form-Secret: <this value>
# FORM_SUBMIT_SECRET=your-long-random-secret-string
